# Lean fiesta-only runtime image for the OSG plugin (pure-Fiesta path).
# No NMMA: just fiesta + jax + blackjax (the blackjax-smc sampler) + a baked
# surrogate. The plugin ships fiesta_wrapper.py + fiesta_bridge.py per-job, so
# this image is a generic fiesta runtime (no plugin code baked in).
#
#   apptainer build --fakeroot --mksquashfs-args "-processors 1" fiesta.sif fiesta.def
# GPU variant: add `pip3 install "jax[cuda12]"` and run with request_gpus=1.
Bootstrap: docker
From: ubuntu:24.04

%post
    set -e
    export PIP_BREAK_SYSTEM_PACKAGES=1 DEBIAN_FRONTEND=noninteractive
    apt-get update
    apt-get install -y python3 python3-pip git build-essential
    apt-get clean && rm -rf /var/lib/apt/lists/*

    pip3 install uv
    uv pip install --system --break-system-packages fiestaem blackjax

    # Bake the KN surrogate (a read-only .sif can't download on a worker).
    python3 -c "from fiesta.surrogates.manage_surrogates import download_surrogate; download_surrogate('Bu2025_MLP')"

    # Fail the build if the runtime isn't importable.
    python3 -c "import fiesta, blackjax, jax; print('fiesta+blackjax+jax', jax.__version__)"

%runscript
    exec python3 "$@"
